{
  "name": "fast-sudoku-solver",
  "version": "3.0.2",
  "description": "A fast Sudoku solver written in TypeScript.",
  "homepage": "https://github.com/luth1um/sudoku-solver-typescript#readme",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "lint": "oxlint --fix --deny-warnings",
    "format": "prettier --write \"./**/*.{js,json,md,ts,yaml,yml}\"",
    "test": "vitest run",
    "clean": "node -e \"['dist'].forEach(p => fs.rmSync(p, { recursive: true, force: true }))\"",
    "build": "tsc",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luth1um/sudoku-solver-typescript.git"
  },
  "bugs": {
    "url": "https://github.com/luth1um/sudoku-solver-typescript/issues"
  },
  "keywords": [
    "sudoku",
    "puzzle",
    "solver"
  ],
  "author": "luthium",
  "license": "MIT",
  "devDependencies": {
    "husky": "^9.1.7",
    "nano-staged": "^1.0.2",
    "oxlint": "^1.59.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "nano-staged": {
    "*.{ts,js}": [
      "prettier --write",
      "oxlint --fix --deny-warnings"
    ],
    "*.{json,md,yaml,yml}": "prettier --write"
  }
}
